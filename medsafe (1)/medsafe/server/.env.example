# PORT=5000
# MONGO_URI=mongodb://127.0.0.1:27017/medsafe
# Set to true for local dev without Atlas or a local MongoDB install (downloads binary on first run)
# USE_MEMORY_DB=true
# OCR_SERVICE_URL=http://localhost:8000
# CLIENT_ORIGIN=http://localhost:5173
#
# Production (Render): set CLIENT_ORIGIN to your Vercel URL, comma-separated if you use previews + prod:
# CLIENT_ORIGIN=https://medsafe.vercel.app,https://medsafe-git-main-yourteam.vercel.app
# USE_MEMORY_DB=false
# PORT is usually set automatically by Render.
